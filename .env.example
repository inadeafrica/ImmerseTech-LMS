# Copy to .env and adjust before running `docker compose up`.
# All values below are safe local-dev defaults — replace before deploying anywhere shared.

MARIADB_ROOT_PASSWORD=changeme

MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=changeme

MOODLE_HTTP_PORT=8080
MOODLE_WWWROOT=http://localhost:8080

# Used only for the one-time CLI install command (see README) — Moodle itself
# doesn't read these from the environment.
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=changeme
MOODLE_ADMIN_EMAIL=admin@immersetech.example
